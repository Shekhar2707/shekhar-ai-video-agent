# =============================================
# ShekarAI - Environment Configuration
# =============================================
# Copy this file to .env and fill in values

# --- App ---
PORT=4000
NODE_ENV=production

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# --- YouTube (Google OAuth) ---
YOUTUBE_CLIENT_ID=your-google-client-id
YOUTUBE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:4000/oauth2callback
YOUTUBE_REFRESH_TOKEN=your-refresh-token-after-first-auth

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/shekarai

# --- Channel Info ---
YOUTUBE_CHANNEL_NAME=Digital Shekhar
YOUTUBE_CATEGORY_ID=22

# --- Processing Limits ---
MAX_RAM_MB=1536
MAX_CPU_PERCENT=60
SAFE_HOUR_START=0
SAFE_HOUR_END=5

# --- Paths ---
TEMP_DIR=/tmp/shekarai
OUTPUT_DIR=/var/www/shekarai/output
MUSIC_DIR=/var/www/shekarai/music
ASSETS_DIR=/var/www/shekarai/assets

# --- Notification (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
